<%= form_with model: receipt, class: "space-y-5" do |f| %>
  <% if receipt.errors.any? %>
    <div class="rounded-2xl border border-rose-400/40 bg-rose-500/10 p-4">
      <p class="mb-2 text-sm font-semibold text-rose-100">Please fix the following:</p>
      <ul class="list-disc space-y-1 pl-5 text-sm text-rose-100">
        <% receipt.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :merchant, class: "mb-1 block text-sm font-medium text-slate-300" %>
    <%= f.text_field :merchant, class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 placeholder:text-slate-500 focus:border-cyan-400 focus:outline-none" %>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :amount, class: "mb-1 block text-sm font-medium text-slate-300" %>
      <%= f.number_field :amount, step: "0.01", min: "0", class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 focus:border-cyan-400 focus:outline-none" %>
    </div>

    <div>
      <%= f.label :purchase_date, class: "mb-1 block text-sm font-medium text-slate-300" %>
      <%= f.date_field :purchase_date, class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 focus:border-cyan-400 focus:outline-none" %>
    </div>
  </div>

  <div>
    <%= f.label :category, class: "mb-1 block text-sm font-medium text-slate-300" %>
    <%= f.select :category,
                 options_for_select([ "Groceries", "Dining", "Transport", "Shopping", "Utilities", "Health", "Other" ], receipt.category),
                 { prompt: "Select a category" },
                 class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 focus:border-cyan-400 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :notes, class: "mb-1 block text-sm font-medium text-slate-300" %>
    <%= f.text_area :notes, rows: 4, class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 focus:border-cyan-400 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :image, "Receipt image", class: "mb-1 block text-sm font-medium text-slate-300" %>
    <%= f.file_field :image, accept: "image/*", class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 file:mr-3 file:rounded-md file:border-0 file:bg-cyan-500/20 file:px-3 file:py-2 file:text-sm file:font-semibold file:text-cyan-100 hover:file:bg-cyan-500/30" %>
    <% if receipt.image.attached? %>
      <p class="mt-2 text-xs text-slate-400">Current file: <%= receipt.image.filename %></p>
    <% end %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "rounded-full border border-cyan-300/50 bg-cyan-500/20 px-4 py-2 text-sm font-semibold text-cyan-100 hover:bg-cyan-500/30" %>
    <%= link_to "Cancel", receipts_path, class: "text-sm font-medium text-slate-400 hover:text-slate-200" %>
  </div>
<% end %>
