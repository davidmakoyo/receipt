<% content_for :title, "Receipts" %>

<div data-controller="claim-report">
<section class="mb-6 flex flex-wrap items-center justify-between gap-3">
  <div>
    <h1 class="font-[Space_Grotesk] text-3xl font-bold tracking-tight text-slate-100">Receipt Vault</h1>
    <p class="text-sm text-slate-300">Your private receipt timeline, fully searchable.</p>
  </div>
  <div class="flex items-center gap-2">
    <button
      type="button"
      data-action="claim-report#toggleMode"
      data-claim-report-target="selectionButton"
      class="rounded-full border border-cyan-300/40 bg-cyan-500/20 px-4 py-2 text-sm font-semibold text-cyan-100 hover:bg-cyan-500/30"
    >
      Generate Report
    </button>
    <%= link_to "Add Receipt", new_receipt_path, class: "rounded-full border border-indigo-300/40 bg-indigo-500/20 px-4 py-2 text-sm font-semibold text-indigo-100 hover:bg-indigo-500/30" %>
  </div>
</section>

<section class="mb-6 hidden rounded-3xl border border-cyan-400/30 bg-cyan-500/10 p-4 text-sm text-cyan-100" data-claim-report-target="selectionNote">
  Claim mode is active. Click the + next to receipts to include them in your lost luggage claim.
  Selected: <span data-claim-report-target="counter">0</span>
  <form action="<%= claim_report_receipts_path(format: :pdf) %>" method="get" class="mt-3 hidden" data-claim-report-target="exportForm">
    <span data-claim-report-target="hiddenIds"></span>
    <button type="submit" class="rounded-full border border-cyan-300/50 bg-cyan-500/20 px-4 py-2 text-sm font-semibold text-cyan-100 hover:bg-cyan-500/30 disabled:cursor-not-allowed disabled:opacity-40">
      Export Claim Report PDF
    </button>
  </form>
</section>

<section class="mb-6 rounded-3xl border border-slate-700/60 bg-slate-900/70 p-4 shadow-xl shadow-black/20">
  <%= form_with url: receipts_path, method: :get, local: true, class: "grid gap-4 lg:grid-cols-3" do %>
    <div>
      <label for="merchant" class="mb-1 block text-sm font-medium text-slate-300">Merchant</label>
      <%= text_field_tag :merchant, params[:merchant], placeholder: "Search merchant", class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 placeholder:text-slate-500 focus:border-cyan-400 focus:outline-none" %>
    </div>
    <div>
      <label for="start_date" class="mb-1 block text-sm font-medium text-slate-300">Start date</label>
      <%= date_field_tag :start_date, params[:start_date], class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 focus:border-cyan-400 focus:outline-none" %>
    </div>
    <div>
      <label for="end_date" class="mb-1 block text-sm font-medium text-slate-300">End date</label>
      <%= date_field_tag :end_date, params[:end_date], class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 focus:border-cyan-400 focus:outline-none" %>
    </div>
    <div>
      <label for="min_amount" class="mb-1 block text-sm font-medium text-slate-300">Min amount</label>
      <%= number_field_tag :min_amount, params[:min_amount], step: "0.01", min: "0", class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 focus:border-cyan-400 focus:outline-none" %>
    </div>
    <div>
      <label for="max_amount" class="mb-1 block text-sm font-medium text-slate-300">Max amount</label>
      <%= number_field_tag :max_amount, params[:max_amount], step: "0.01", min: "0", class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 focus:border-cyan-400 focus:outline-none" %>
    </div>
    <div class="flex items-end gap-2">
      <%= submit_tag "Apply filters", class: "rounded-full border border-cyan-300/50 bg-cyan-500/20 px-4 py-2 text-sm font-semibold text-cyan-100 hover:bg-cyan-500/30" %>
      <%= link_to "Clear", receipts_path, class: "rounded-full border border-slate-600 px-4 py-2 text-sm font-medium text-slate-300 hover:bg-slate-800/80" %>
    </div>
  <% end %>
</section>

<section class="overflow-hidden rounded-3xl border border-slate-700/60 bg-slate-900/70 shadow-xl shadow-black/20">
  <% if @receipts.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-800">
        <thead class="bg-slate-950/70">
          <tr>
            <th class="hidden px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400" data-report-toggle>Select</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Merchant</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Category</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">Date</th>
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-400">Amount</th>
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-400">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800/80">
          <% @receipts.each do |receipt| %>
            <tr class="transition hover:bg-slate-800/55">
              <td class="hidden px-4 py-3 text-sm" data-report-toggle>
                <button
                  type="button"
                  data-report-select
                  data-receipt-id="<%= receipt.id %>"
                  data-action="claim-report#toggleReceipt"
                  class="rounded-full border border-slate-600 px-3 py-1 text-sm font-semibold text-slate-100 hover:bg-slate-700/70"
                >
                  +
                </button>
              </td>
              <td class="px-4 py-3 text-sm font-semibold text-slate-100"><%= receipt.merchant %></td>
              <td class="px-4 py-3 text-sm text-slate-300"><%= receipt.category %></td>
              <td class="px-4 py-3 text-sm text-slate-300"><%= receipt.purchase_date.strftime("%b %d, %Y") %></td>
              <td class="px-4 py-3 text-right text-sm font-semibold text-cyan-200"><%= number_to_currency(receipt.amount) %></td>
              <td class="px-4 py-3 text-right text-sm">
                <%= link_to "View", receipt_path(receipt), class: "font-medium text-violet-200 hover:text-violet-100" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-sm text-slate-400">
        <%= params.slice(:merchant, :start_date, :end_date, :min_amount, :max_amount).values.any?(&:present?) ? "No receipts match the current filters." : "No receipts yet. Add your first one to get started." %>
      </p>
    </div>
  <% end %>
</section>

</div>
