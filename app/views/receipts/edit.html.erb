<% content_for :title, "Edit Receipt" %>

<section class="mx-auto max-w-3xl">
  <h1 class="mb-1 font-[Space_Grotesk] text-3xl font-bold tracking-tight text-slate-100">Edit Receipt</h1>
  <p class="mb-6 text-sm text-slate-300">Update details for <%= @receipt.merchant %>.</p>

  <div class="rounded-3xl border border-slate-700/60 bg-slate-900/70 p-6 shadow-xl shadow-black/20">
    <%= render "form", receipt: @receipt %>
  </div>
</section>
