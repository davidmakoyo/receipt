<% content_for :title, @receipt.merchant %>

<section class="mb-6 flex flex-wrap items-center justify-between gap-3">
  <div>
    <h1 class="font-[Space_Grotesk] text-3xl font-bold tracking-tight text-slate-100"><%= @receipt.merchant %></h1>
    <p class="text-sm text-slate-300">Purchased on <%= @receipt.purchase_date.strftime("%b %d, %Y") %></p>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to "Edit", edit_receipt_path(@receipt), class: "rounded-full border border-slate-600 px-4 py-2 text-sm font-medium text-slate-200 hover:bg-slate-800/80" %>
    <%= button_to "Delete", receipt_path(@receipt), method: :delete, data: { turbo_confirm: "Delete this receipt?" }, class: "rounded-full border border-rose-400/40 bg-rose-500/20 px-4 py-2 text-sm font-semibold text-rose-100 hover:bg-rose-500/30" %>
  </div>
</section>

<section class="grid gap-6 lg:grid-cols-2">
  <article class="rounded-3xl border border-slate-700/60 bg-slate-900/70 p-5 shadow-xl shadow-black/20">
    <h2 class="font-[Space_Grotesk] text-xl font-semibold text-slate-100">Details</h2>
    <dl class="mt-4 space-y-3">
      <div class="flex items-center justify-between border-b border-slate-700/80 pb-2">
        <dt class="text-sm text-slate-300">Amount</dt>
        <dd class="text-sm font-semibold text-cyan-200"><%= number_to_currency(@receipt.amount) %></dd>
      </div>
      <div class="flex items-center justify-between border-b border-slate-700/80 pb-2">
        <dt class="text-sm text-slate-300">Category</dt>
        <dd class="text-sm font-semibold text-violet-200"><%= @receipt.category %></dd>
      </div>
      <div>
        <dt class="mb-1 text-sm text-slate-300">Notes</dt>
        <dd class="text-sm text-slate-200"><%= @receipt.notes.presence || "No notes added." %></dd>
      </div>
    </dl>
  </article>

  <article class="rounded-3xl border border-slate-700/60 bg-slate-900/70 p-5 shadow-xl shadow-black/20">
    <h2 class="font-[Space_Grotesk] text-xl font-semibold text-slate-100">Receipt image</h2>
    <% if @receipt.image.attached? %>
      <div class="mt-4 overflow-hidden rounded-2xl border border-slate-700 bg-slate-950/70 p-2">
        <%= image_tag @receipt.image, class: "h-auto w-full rounded-lg object-contain" %>
      </div>
    <% else %>
      <p class="mt-4 text-sm text-slate-400">No image uploaded for this receipt.</p>
    <% end %>
  </article>
</section>
