<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Receipt Rescue" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Receipt Rescue">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>


    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.svg">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-950 text-slate-100 font-[Manrope]">
    <div class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(circle_at_15%_20%,rgba(6,182,212,0.22),transparent_35%),radial-gradient(circle_at_85%_10%,rgba(99,102,241,0.22),transparent_35%),linear-gradient(to_bottom_right,#020617,#0b1120,#020617)]"></div>
    <header class="sticky top-0 z-30 border-b border-slate-800/80 bg-slate-950/80 backdrop-blur-xl">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <%= link_to "Receipt Rescue", (user_signed_in? ? dashboard_path : new_user_session_path), class: "font-[Space_Grotesk] text-xl font-bold tracking-wide text-cyan-300" %>
        <% if user_signed_in? %>
          <div class="flex items-center gap-2 sm:gap-4">
            <%= link_to "Dashboard", dashboard_path, class: "rounded-full border border-slate-700/60 px-3 py-2 text-sm font-semibold text-slate-200 transition hover:border-cyan-300/60 hover:bg-slate-800/80 hover:text-cyan-200" %>
            <%= link_to "Receipts", receipts_path, class: "rounded-full border border-slate-700/60 px-3 py-2 text-sm font-semibold text-slate-200 transition hover:border-cyan-300/60 hover:bg-slate-800/80 hover:text-cyan-200" %>
            <%= link_to "Add Receipt", new_receipt_path, class: "rounded-full border border-indigo-400/50 bg-indigo-500/20 px-3 py-2 text-sm font-semibold text-indigo-100 transition hover:bg-indigo-500/30" %>
            <span class="hidden rounded-full border border-slate-700/70 bg-slate-900/70 px-3 py-2 text-sm font-medium text-slate-300 sm:inline"><%= current_user.username %></span>
            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "rounded-full border border-rose-400/40 bg-rose-500/20 px-3 py-2 text-sm font-semibold text-rose-100 transition hover:bg-rose-500/30" %>
          </div>
        <% end %>
      </nav>
    </header>

    <div class="mx-auto w-full max-w-6xl px-4 pt-6 sm:px-6 lg:px-8">
      <% if notice.present? %>
        <div class="mb-4 rounded-2xl border border-emerald-400/35 bg-emerald-500/10 px-4 py-3 text-sm font-medium text-emerald-100"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-4 rounded-2xl border border-rose-400/35 bg-rose-500/10 px-4 py-3 text-sm font-medium text-rose-100"><%= alert %></div>
      <% end %>
    </div>

    <main class="mx-auto w-full max-w-6xl px-4 pb-10 sm:px-6 lg:px-8">
      <%= yield %>
    </main>
  </body>
</html>
