<section class="mx-auto mt-10 w-full max-w-md rounded-3xl border border-slate-700/60 bg-slate-900/70 p-6 shadow-xl shadow-black/20">
  <h2 class="font-[Space_Grotesk] text-2xl font-bold text-slate-100">Create account</h2>
  <p class="mt-1 text-sm text-slate-300">Start tracking receipts and monthly spending.</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :username, class: "mb-1 block text-sm font-semibold text-slate-300" %>
      <%= f.text_field :username, autofocus: true, autocomplete: "username", class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 outline-none transition focus:border-cyan-400 focus:ring-2 focus:ring-cyan-500/30" %>
    </div>

    <div>
      <%= f.label :email, class: "mb-1 block text-sm font-semibold text-slate-300" %>
      <%= f.email_field :email, autocomplete: "email", class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 outline-none transition focus:border-cyan-400 focus:ring-2 focus:ring-cyan-500/30" %>
    </div>

    <div>
      <%= f.label :password, class: "mb-1 block text-sm font-semibold text-slate-300" %>
      <% if @minimum_password_length %>
        <p class="mb-1 text-xs text-slate-500"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 outline-none transition focus:border-cyan-400 focus:ring-2 focus:ring-cyan-500/30" %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "mb-1 block text-sm font-semibold text-slate-300" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 outline-none transition focus:border-cyan-400 focus:ring-2 focus:ring-cyan-500/30" %>
    </div>

    <%= f.submit "Sign up", class: "w-full rounded-full border border-cyan-300/50 bg-cyan-500/20 px-4 py-2 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-500/30" %>
  <% end %>

  <div class="mt-4 text-sm text-slate-400">
    <%= render "devise/shared/links" %>
  </div>
</section>
