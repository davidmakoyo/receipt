<section class="mx-auto mt-10 w-full max-w-md rounded-3xl border border-slate-700/60 bg-slate-900/70 p-6 shadow-xl shadow-black/20">
  <h2 class="font-[Space_Grotesk] text-2xl font-bold text-slate-100">Welcome back</h2>
  <p class="mt-1 text-sm text-slate-300">Log in to manage your receipts and spending dashboard.</p>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
    <div>
      <%= f.label :email, class: "mb-1 block text-sm font-semibold text-slate-300" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 outline-none transition focus:border-cyan-400 focus:ring-2 focus:ring-cyan-500/30" %>
    </div>

    <div>
      <%= f.label :password, class: "mb-1 block text-sm font-semibold text-slate-300" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded-xl border border-slate-700 bg-slate-950/80 px-3 py-2 text-sm text-slate-100 outline-none transition focus:border-cyan-400 focus:ring-2 focus:ring-cyan-500/30" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-2">
        <%= f.check_box :remember_me, class: "rounded border-slate-500 bg-slate-900 text-cyan-400 focus:ring-cyan-500" %>
        <%= f.label :remember_me, class: "text-sm text-slate-400" %>
      </div>
    <% end %>

    <%= f.submit "Log in", class: "w-full rounded-full border border-cyan-300/50 bg-cyan-500/20 px-4 py-2 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-500/30" %>
  <% end %>

  <div class="mt-4 text-sm text-slate-400">
    <%= render "devise/shared/links" %>
  </div>
</section>
